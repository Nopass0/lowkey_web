APP_ENV=main
FRONTEND_BIND_PORT=3303
BACKEND_BIND_PORT=3302
VOIDDB_BIND_PORT=7711
BITLLM_BIND_PORT=8180
VOIDDB_API_KEY=english-voiddb-key
NEXT_PUBLIC_SITE_URL=https://english.lowkey.su
NEXT_PUBLIC_API_URL=/api
BACKEND_INTERNAL_URL=http://backend:3002
CORS_ORIGINS=https://english.lowkey.su
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=lowkey_english_bot
