HOST=0.0.0.0
PORT=3002
JWT_SECRET=change-this-to-a-secure-random-string

# VoidDB (shared db.lowkey.su instance, separate database "english")
VOIDDB_URL=https://db.lowkey.su
VOIDDB_DATABASE=english
VOIDDB_USERNAME=admin
VOIDDB_PASSWORD=
VOIDDB_TOKEN=

# Telegram bot
TELEGRAM_BOT_TOKEN=your-bot-token-from-botfather
TELEGRAM_WEBHOOK_URL=https://english.lowkey.su

# YooKassa payments
YOKASSA_SHOP_ID=your-shop-id
YOKASSA_SECRET=your-secret-key
YOKASSA_TEST_SHOP_ID=your-test-shop-id
YOKASSA_TEST_SECRET=your-test-secret-key
YOKASSA_TEST_MODE=true

# OpenRouter AI
OPENROUTER_URL=https://openrouter.ai/api/v1
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_SITE_URL=http://localhost:3003
OPENROUTER_SITE_NAME=LowKey English
OPENROUTER_TEMPERATURE=0.7
OPENROUTER_MAX_TOKENS=2048

# File uploads
UPLOADS_DIR=./uploads

# HuggingFace (for TTS & speech analysis)
HF_API_TOKEN=
HF_TTS_MODEL=hexgrad/Kokoro-82M
HF_SPEECH_MODEL=openai/whisper-small

# Frontend URL (for payment redirects and Telegram links)
FRONTEND_URL=http://localhost:3003
CORS_ORIGINS=http://localhost:3003,http://127.0.0.1:3003,https://english.lowkey.su
