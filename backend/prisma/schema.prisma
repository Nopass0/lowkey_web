generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                        String            @id @default(uuid())
  login                     String            @unique
  passwordHash              String
  balance                   Float             @default(0)
  referralBalance           Float             @default(0)
  isBanned                  Boolean           @default(false)
  isAdmin                   Boolean           @default(false)
  referralCode              String            @unique
  referredById              String?
  joinedAt                  DateTime          @default(now())
  pendingDiscountFixed      Float             @default(0)
  pendingDiscountPct        Float             @default(0)
  botLoginCode              String?
  botLoginCodeExpiresAt     DateTime?
  telegramId                BigInt?           @unique
  telegramLinkCode          String?           @unique
  telegramLinkCodeExpiresAt DateTime?
  botState                  String? // For managing interactive flows (e.g., "admin_search_user", "withdraw_step_1")
  tempReferrerId            String? // temporary storage for referral link between /start and link
  referralRate              Float             @default(0.2)
  devices                   Device[]
  payments                  Payment[]
  promoActivations          PromoActivation[]
  subscription              Subscription?
  supportTickets            SupportTicket[]
  transactions              Transaction[]
  referredBy                User?             @relation("Referrals", fields: [referredById], references: [id])
  referrals                 User[]            @relation("Referrals")
  vpnTokens                 VpnToken[]
  withdrawals               Withdrawal[]
  financeWithdrawalsCreated FinanceWithdrawal[]

  @@map("users")
}

model SubscriptionPlan {
  id        String              @id @default(uuid())
  slug      String              @unique
  name      String
  features  String[]
  isPopular Boolean             @default(false)
  isActive  Boolean             @default(true)
  sortOrder Int                 @default(0)
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt
  prices    SubscriptionPrice[]

  @@map("subscription_plans")
}

model SubscriptionPrice {
  id     String           @id @default(uuid())
  planId String
  period String
  price  Float
  plan   SubscriptionPlan @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@unique([planId, period])
  @@map("subscription_prices")
}

model Subscription {
  id          String   @id @default(uuid())
  userId      String   @unique
  planId      String
  planName    String
  activeUntil DateTime
  isLifetime  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  autoRenewal Boolean  @default(true)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}

model Transaction {
  id        String   @id @default(uuid())
  userId    String
  type      String
  amount    Float
  title     String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("transactions")
}

model Payment {
  id           String   @id @default(uuid())
  userId       String
  sbpPaymentId String   @unique
  amount       Float
  status       String   @default("pending")
  qrUrl        String
  sbpUrl       String
  createdAt    DateTime @default(now())
  expiresAt    DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("payments")
}

model Device {
  id         String     @id @default(uuid())
  userId     String
  name       String
  os         String
  version    String
  lastIp     String
  isBlocked  Boolean    @default(false)
  lastSeenAt DateTime   @default(now())
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  vpnTokens  VpnToken[]

  @@index([userId])
  @@map("devices")
}

model PromoCode {
  id             String            @id @default(uuid())
  code           String            @unique
  conditions     Json
  effects        Json
  maxActivations Int?
  createdAt      DateTime          @default(now())
  activations    PromoActivation[]

  @@map("promo_codes")
}

model PromoActivation {
  id          String    @id @default(uuid())
  userId      String
  promoCodeId String
  activatedAt DateTime  @default(now())
  promoCode   PromoCode @relation(fields: [promoCodeId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, promoCodeId])
  @@map("promo_activations")
}

model Withdrawal {
  id          String    @id @default(uuid())
  userId      String
  amount      Float
  target      String
  bank        String
  status      String    @default("pending")
  createdAt   DateTime  @default(now())
  processedAt DateTime?
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("withdrawals")
}

model FinanceWithdrawal {
  id             String    @id @default(uuid())
  title          String
  note           String?
  amount         Float
  withdrawalDate DateTime
  createdAt      DateTime  @default(now())
  createdById    String?
  createdBy      User?     @relation(fields: [createdById], references: [id], onDelete: SetNull)

  @@index([withdrawalDate])
  @@map("finance_withdrawals")
}

model FinanceSettings {
  id                String   @id @default("global")
  taxRate           Float    @default(0)
  acquiringFeeRate  Float    @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@map("finance_settings")
}

model AppRelease {
  id            String   @id @default(uuid())
  platform      String
  version       String
  changelog     String
  downloadUrl   String
  fileSizeMb    Float
  downloadCount Int      @default(0)
  isLatest      Boolean  @default(false)
  createdAt     DateTime @default(now())

  @@map("app_releases")
}

model SupportTicket {
  id        String   @id @default(uuid())
  userId    String
  message   String
  reply     String?
  status    String   @default("open")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("support_tickets")
}

model VpnServer {
  id                  String   @id @default(uuid())
  ip                  String
  port                Int
  status              String   @default("offline")
  currentLoad         Int      @default(0)
  lastSeenAt          DateTime @default(now())
  createdAt           DateTime @default(now())
  serverType          String
  supportedProtocols  String[]
  location            String   @default("Unknown, UN")
  connectLinkTemplate String?

  @@unique([ip, port])
  @@map("vpn_servers")
}

model VpnToken {
  id        String   @id @default(uuid())
  userId    String
  deviceId  String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  device    Device   @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, deviceId])
  @@map("vpn_tokens")
}
