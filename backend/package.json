{
  "name": "lowkey-vpn-backend",
  "version": "1.0.0",
  "description": "Backend API for lowkey VPN",
  "type": "module",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "build": "bun build src/index.ts --outdir ./dist --target bun",
    "start": "bun run src/index.ts",
    "db:init": "bunx vdb init",
    "db:pull": "bunx vdb pull",
    "db:push": "bunx vdb push",
    "db:generate": "bunx vdb gen",
    "db:status": "bunx vdb status",
    "db:import:legacy": "bun run src/scripts/import-legacy-data.ts"
  },
  "dependencies": {
    "@elysiajs/cors": "^1.3.1",
    "@elysiajs/swagger": "^1.3.1",
    "@voiddb/orm": "^1.2.3",
    "@vercel/blob": "^1.1.1",
    "bcryptjs": "^3.0.2",
    "elysia": "^1.3.1",
    "jose": "^6.0.11",
    "tochka-sbp": "^1.0.0"
  },
  "devDependencies": {
    "@prisma/client": "^6.5.0",
    "@types/bcryptjs": "^3.0.0",
    "bun-types": "latest",
    "ioredis": "^5.6.1",
    "prisma": "^6.5.0",
    "typescript": "^5.8.2"
  }
}
